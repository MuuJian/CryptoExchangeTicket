{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Realtime OI Dashboard",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/realtime_oi_dashboard/server.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": [
        "--oi-batch-size",
        "25",
        "--oi-batch-delay",
        "1",
        "--oi-workers",
        "3",
      ],
      "serverReadyAction": {
        "pattern": "Dashboard running at (http://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Index Constituents",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/index_constituents/server.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": [
        "--port",
        "8788",
        "--workers",
        "12"
      ],
      "serverReadyAction": {
        "pattern": "Index constituents dashboard running at (http://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Generate Watchlists",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
