{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Realtime OI Dashboard",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/realtime_oi_dashboard/server.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": [
        "--oi-batch-size",
        "25",
        "--oi-batch-delay",
        "1"
      ],
      "serverReadyAction": {
        "pattern": "Dashboard running at (http://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
  },
  {
    "name": "ath_atl",
    "type": "python",
    "request": "launch",
    "module": "ath_atl.web",
    "cwd": "${workspaceFolder}",
    "console": "integratedTerminal",
    "justMyCode": true,
    "args": [
      "--port",
      "8788",
      "--scan-workers",
      "1",
      "--retry-attempts",
      "6",
      "--retry-backoff",
      "2"
    ],
    "serverReadyAction": {
      "pattern": "ATH/ATL page: (http://\\S+)",
      "uriFormat": "%s",
      "action": "openExternally"
    }
  }

  ]
}
